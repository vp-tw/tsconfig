{
  "name": "@vp-tw/tsconfig",
  "version": "5.0.0",
  "description": "Common tsconfig presets collection",
  "keywords": [
    "config",
    "emotion",
    "node",
    "preset",
    "react",
    "tsconfig",
    "typescript",
    "vite"
  ],
  "license": "MIT",
  "author": {
    "name": "ViPro",
    "email": "vdustr@gmail.com",
    "url": "http://vdustr.dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vp-tw/tsconfig.git"
  },
  "files": [
    "base",
    "CHANGELOG.md",
    "ext"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./base/*/tsconfig": "./base/*/tsconfig.json",
    "./base/*/tsconfig.json": "./base/*/tsconfig.json",
    "./ext/*/tsconfig": "./ext/*/tsconfig.json",
    "./ext/*/tsconfig.json": "./ext/*/tsconfig.json",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@tsconfig/node-lts": "catalog:",
    "@tsconfig/node-ts": "catalog:",
    "@tsconfig/node24": "catalog:",
    "@tsconfig/strictest": "catalog:",
    "@tsconfig/vite-react": "catalog:"
  }
}
